PORT=3000
NODE_ENV=development

# Reverse Proxy Configuration
# Set to true if running behind NGINX, Cloudflare, or other reverse proxies
# This enables proper IP detection via X-Forwarded-For header
TRUST_PROXY=false

# Allow or block reverse proxy requests
# Set to false to block all X-Forwarded-For headers (reject reverse proxy requests)
# Set to true to allow reverse proxies (can optionally restrict to specific IPs with REVERSE_PROXY_IPS)
ALLOW_REVERSE_PROXIES=true

# Restrict reverse proxies to specific IPs
# Only used if ALLOW_REVERSE_PROXIES=true
# Comma-separated list of allowed reverse proxy IPs (the IPs directly connecting to this server)
# Leave empty to allow any reverse proxy
REVERSE_PROXY_IPS=

# IP Whitelisting Configuration
# Enable IP whitelisting for protected endpoints
IP_WHITELIST_ENABLED=false

# ACNH Bot IP Addresses
# Comma-separated list of IPs allowed to communicate with this API
ALLOWED_IPS=